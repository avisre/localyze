# Google Play Console credentials
# These are sensitive — never commit the real .env file
PLAY_CONSOLE_EMAIL=your-email@gmail.com
PLAY_CONSOLE_PASSWORD=your-password

# Account and app identifiers
# Developer ID from the Play Console URL
DEVELOPER_ID=6492542126543167241
# App ID from the Play Console URL
APP_ID=4974212910605033903

# Path to CSV file containing tester emails for closed testing
# Format: one email per line, or standard CSV with email column
TESTER_CSV_PATH=./testers.csv
