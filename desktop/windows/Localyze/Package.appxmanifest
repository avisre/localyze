<?xml version="1.0" encoding="utf-8"?>
<!--
    Localyze.ai — WinUI 3 MSIX package manifest.

    NOTE on signing: the Publisher CN below ("CN=Localyze") is a placeholder
    that MUST match the Subject of the code-signing certificate used by
    `build-msix.ps1`. Before shipping a real release, replace it with the
    Subject (DN) of your real cert, e.g. "CN=Localyze AI Ltd, O=Localyze AI Ltd,
    L=City, S=State, C=Country". The Identity Name (`LocalyzeAI.Desktop`) is the
    fixed family name and does not change between builds.

    The icon paths under VisualElements are declared here; the actual PNGs live
    in `Assets/` — see `Assets/README.txt` for the required sizes. Placeholders
    are fine for development; the Store / sideload UX will show the default
    Windows tile until real icons are dropped in.
-->
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap uap10 rescap">

  <Identity
      Name="LocalyzeAI.Desktop"
      Publisher="CN=Localyze"
      Version="1.0.0.0"
      ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Localyze.ai</DisplayName>
    <PublisherDisplayName>Localyze</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <Description>On-device AI chat with Gemma 4 E4B</Description>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="LocalyzeApp"
                 Executable="Localyze.exe"
                 EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
          DisplayName="Localyze.ai"
          Description="On-device AI chat with Gemma 4 E4B"
          BackgroundColor="transparent"
          Square150x150Logo="Assets\Square150x150Logo.png"
          Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
            Wide310x150Logo="Assets\Wide310x150Logo.png"
            ShortName="Localyze">
          <uap:ShowNameOnTiles>
            <uap:ShowOn Tile="square150x150Logo" />
            <uap:ShowOn Tile="wide310x150Logo" />
          </uap:ShowNameOnTiles>
        </uap:DefaultTile>
        <uap:SplashScreen Image="Assets\StoreLogo.png" BackgroundColor="#1A1A1A" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Needed so the first-run flow can stream the ~5 GB Gemma 4 E4B ONNX model from CDN. -->
    <Capability Name="internetClient" />
    <!-- Required because we ship as a full-trust desktop app (file I/O outside the package
         sandbox, DXGI/DXCore probes, ONNX Runtime native DLLs, optional CUDA/QNN providers). -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
