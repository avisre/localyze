<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Localyze.Artifacts.ArtifactView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls">
    <Grid Padding="8" RowDefinitions="Auto,*,Auto" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
        <TextBlock x:Name="TitleText" Grid.Row="0" FontWeight="SemiBold" />
        <ContentControl x:Name="BodyHost" Grid.Row="1" HorizontalContentAlignment="Stretch" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
            <Button Content="Save" Click="OnSave" />
            <Button Content="PDF"  Click="OnPdf"  />
        </StackPanel>
    </Grid>
</UserControl>
