<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Localyze.Views.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowDefinitions="Auto,*,Auto" Padding="12">
        <TextBlock x:Name="StatusBar" Grid.Row="0" Margin="0,0,0,8" Opacity="0.7" />
        <ScrollViewer Grid.Row="1" x:Name="MessagesScroll">
            <StackPanel x:Name="MessagesPanel" Spacing="8" />
        </ScrollViewer>
        <Grid Grid.Row="2" Margin="0,8,0,0" ColumnDefinitions="*,Auto,Auto,Auto">
            <TextBox x:Name="InputBox" Grid.Column="0" PlaceholderText="Ask Localyze…" AcceptsReturn="True" TextWrapping="Wrap" />
            <ToggleSwitch x:Name="WebSearchToggle" Grid.Column="1" Margin="8,0" Header="Web" OffContent="Off" OnContent="On" />
            <ToggleSwitch x:Name="CodeExecToggle" Grid.Column="2" Margin="8,0" Header="Code exec" OffContent="Off" OnContent="On" />
            <Button x:Name="SendButton" Grid.Column="3" Content="Send" Click="OnSend" />
        </Grid>
    </Grid>
</UserControl>
