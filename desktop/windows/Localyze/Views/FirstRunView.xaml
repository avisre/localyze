<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Localyze.Views.FirstRunView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="32" RowDefinitions="Auto,*,Auto">

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Welcome to Localyze.ai" FontSize="28" FontWeight="SemiBold" />
            <TextBlock x:Name="StepLabel" Text="Step 1 of 3 — Detecting your hardware" Opacity="0.7" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,24,0,0">

            <!-- Step 1: hardware probe -->
            <StackPanel x:Name="Step1Panel" Spacing="12" Visibility="Visible">
                <ProgressRing x:Name="ProbeSpinner" IsActive="True" Width="48" Height="48" HorizontalAlignment="Left" />
                <TextBlock x:Name="ProbeStatus" Text="Detecting your hardware…" FontSize="16" />
                <Border CornerRadius="6" Padding="16" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                    <TextBlock x:Name="ProbeReport" TextWrapping="Wrap" FontFamily="Consolas" />
                </Border>
                <TextBlock x:Name="ProbeError" Foreground="Red" TextWrapping="Wrap" Visibility="Collapsed" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button x:Name="Step1NextButton" Content="Continue" Click="OnStep1Next" IsEnabled="False" />
                </StackPanel>
            </StackPanel>

            <!-- Step 2: model download -->
            <StackPanel x:Name="Step2Panel" Spacing="12" Visibility="Collapsed">
                <TextBlock Text="Download the model" FontSize="20" FontWeight="SemiBold" />
                <TextBlock TextWrapping="Wrap" Opacity="0.8"
                    Text="Localyze.ai runs Google's Gemma 4 E4B on-device. The model is ~5 GB and only needs to be downloaded once. Nothing leaves your machine after this." />
                <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="1" />
                <TextBlock x:Name="DownloadStatus" Text="" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button x:Name="BrowseLocalButton" Content="Browse for local file…" Click="OnBrowseLocal" />
                    <Button x:Name="StartDownloadButton" Content="Start download" Click="OnStartDownload" Style="{ThemeResource AccentButtonStyle}" />
                    <Button x:Name="Step2NextButton" Content="Continue" Click="OnStep2Next" IsEnabled="False" />
                </StackPanel>
            </StackPanel>

            <!-- Step 3: done -->
            <StackPanel x:Name="Step3Panel" Spacing="16" Visibility="Collapsed" VerticalAlignment="Center">
                <TextBlock Text="All set" FontSize="24" FontWeight="SemiBold" />
                <TextBlock TextWrapping="Wrap" Opacity="0.85"
                    Text="Localyze.ai is ready to run. Your conversations, files, and model weights stay on this machine." />
                <Button x:Name="StartChatButton" Content="Start chatting" Click="OnStartChat" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Left" />
            </StackPanel>

        </Grid>

        <TextBlock Grid.Row="2" Text="Gemma 4 E4B by Google • Runs entirely on your device" Opacity="0.5" FontSize="12" />
    </Grid>
</UserControl>
